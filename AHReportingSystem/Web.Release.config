<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <!--
    Web.Release.config: Applied when building in Release configuration (for FTP deployment).
    Update the connection string and other settings for production.
  -->
  <connectionStrings>
    <!--
      Production: SQL Server with SQL Authentication.
      IMPORTANT: Never commit production credentials to Git.
      Replace PROD_SERVER, ah_app_user and CHANGE_ME before deploying via FTP.
    -->
    <add name="AHReportingContext"
         connectionString="Data Source=PROD_SERVER;Initial Catalog=AHReportingSystem;User Id=ah_app_user;Password=CHANGE_ME;Integrated Security=False;MultipleActiveResultSets=True;App=AHReportingSystem"
         providerName="System.Data.SqlClient"
         xdt:Transform="SetAttributes" xdt:Locator="Match(name)" />
  </connectionStrings>
  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />
    <customErrors mode="On" defaultRedirect="~/Error" xdt:Transform="SetAttributes" />
  </system.web>
  <appSettings>
    <add key="LockScreenTimeoutMinutes" value="10"
         xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
  </appSettings>
</configuration>
